# ==============================================================================
# Persistent Remote Services Configuration (config.env)
# ==============================================================================
# Save this file as /etc/claude-remote/config.env or in the script directory.
# Ensure that sensitive variables (like API keys) are secured with proper file
# permissions (chmod 600 config.env).

# ------------------------------------------------------------------------------
# Service Activation
# ------------------------------------------------------------------------------
# Set to 'true' to enable the respective remote service, 'false' to disable/stop.
RUN_CLAUDE=true
RUN_CODEX=false

# ------------------------------------------------------------------------------
# Workspace Directories
# ------------------------------------------------------------------------------
# The folder where the CLI starts. It MUST be trusted beforehand!
# Run the command interactively in this folder once to trust it.
WORKSPACE_DIR=/opt/ai-workspace

# ------------------------------------------------------------------------------
# CLI Paths
# ------------------------------------------------------------------------------
# Absolute paths to the binary executables.
# Default Claude installation: /root/.local/bin/claude
# Default Codex installation: usually in /usr/bin/codex, /usr/local/bin/codex, or /root/.nvm/...
CLAUDE_PATH=/root/.local/bin/claude
CODEX_PATH=/usr/local/bin/codex

# ------------------------------------------------------------------------------
# Codex Authentication Options
# ------------------------------------------------------------------------------
# CODEX_AUTH_TYPE can be:
#   - subscription : uses ChatGPT Pro/Plus/Team logged in via `codex` command.
#                    (requires you to run `codex` manually once as root to log in)
#   - api_key      : uses OpenAI API key specified below.
CODEX_AUTH_TYPE=subscription

# OpenAI API Key (only required if CODEX_AUTH_TYPE=api_key)
OPENAI_API_KEY=your_openai_api_key_here
